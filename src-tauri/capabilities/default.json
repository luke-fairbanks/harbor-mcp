{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window and the tray panel",
  "windows": ["main", "tray"],
  "permissions": [
    "core:default",
    "core:window:allow-start-dragging",
    "core:window:allow-toggle-maximize",
    "opener:default",
    "dialog:default",
    "notification:default"
  ]
}
