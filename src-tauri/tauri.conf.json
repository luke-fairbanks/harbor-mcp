{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Harbor",
  "version": "0.4.1",
  "identifier": "com.harbor.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "Harbor",
        "width": 1080,
        "height": 720,
        "minWidth": 760,
        "minHeight": 480,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "transparent": true,
        "visible": false,
        "windowEffects": {
          "effects": ["sidebar"],
          "state": "followsWindowActiveState"
        }
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["app", "dmg"],
    "category": "DeveloperTool",
    "macOS": {
      "minimumSystemVersion": "11.0",
      "dmg": {
        "background": "dmg-background.png",
        "windowSize": { "width": 600, "height": 400 },
        "appPosition": { "x": 150, "y": 185 },
        "applicationFolderPosition": { "x": 450, "y": 185 }
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEZDNkM5RUU0NUVFMUEzMQpSV1F4R3U1RjdzbkdENkx6bHFwU0dDZFFydUk0MGtrdWFQSkR4TWtVSmRZTk9LTS9zcm8wZFpILwo=",
      "endpoints": [
        "https://github.com/luke-fairbanks/harbor-mcp/releases/latest/download/latest.json"
      ]
    }
  }
}
